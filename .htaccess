# Flower Bloom Studios — static site config
# Every directive is wrapped in <IfModule> so an unsupported module is ignored
# rather than throwing a 500. Safe to delete this file at any time.

# ---------- Correct MIME types ----------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
</IfModule>

# ---------- Compression ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---------- Browser caching ----------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                       "access plus 1 month"
  # HTML stays fresh so edits appear immediately after a deploy
  ExpiresByType text/html              "access plus 0 seconds"
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType text/css               "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|css|js|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
</IfModule>

# ---------- Force HTTPS (canonical protocol) ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Keep the design-prototype folder private (it is not visitor-facing)
  RewriteRule ^project/ - [F,L]
</IfModule>

# NOTE: intentionally NO .html-stripping rewrite. Existing pages are linked and
# canonicalised as .html; stripping would 301 every internal link and canonical.
# New SEO pages use directory form (/web-design-baton-rouge/index.html), which
# already serves a clean URL with no rewriting.
#
# NOTE: intentionally NO "ErrorDocument 404 /index.html" — that returns the
# homepage for missing URLs, which Google treats as a soft 404.
